# FinHub proxy mode: None, Redirect, Forward
# If set, API calls to this FinHub node will be redirected or forwarded to the next FinHub node in the chain.
FINHUB_PROXY_MODE="None"
FINHUB_URL_WEB_CRAWL_NODE="http://localhost:1234"

# If set to True, web crawling requests (made from this node) will be made through the proxy.
FINHUB_FETCH_WEBSITE_VIA_PROXY=True
